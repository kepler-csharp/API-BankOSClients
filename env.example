# ── Base de datos ──────────────────────────────────────────────────
# Si corres el proxy DENTRO de la misma red docker que la DB, usa el
# nombre del servicio (ej: db) y puerto interno 5432.
# Si corres fuera, usa la IP/puerto público (87.99.154.103:5433).
DB_HOST=db
DB_PORT=5432
DB_USER=bankos
DB_PASS=secret

# ── SMTP (Gmail) ───────────────────────────────────────────────────
# 1. Activa la verificación en 2 pasos en tu cuenta Google.
# 2. Crea una "Contraseña de aplicación" de 16 caracteres en:
#    https://myaccount.google.com/apppasswords
# 3. Pega esa contraseña (sin espacios) en SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=xxxxxxxxxxxxxxxx
MAIL_FROM=BankOs <tucorreo@gmail.com>

# NOTA: el correo del administrador NO se configura aquí.
# Cada banco (tenant) tiene su administrador en su propia tabla `users`
# con el rol 'administrador'. Los avisos de registro y PQRS se envían a
# ese correo automáticamente. El remitente (MAIL_FROM/SMTP_USER) es la
# cuenta técnica que despacha los correos, no el admin del banco.
